# Runtime config se učitava iz public/config.js (dev) ili docker/config.template.js (prod).
# Stare VITE_* varijable više nisu u upotrebi — adrese se postavljaju u runtime-u, ne na build.
#
# Za dev (vite proxy radi posao kad je API_BASE_URL prazan, preusmerava na localhost:8080/8081/8082):
#   public/config.js  →  window.APP_CONFIG = { API_BASE_URL: "" };
#
# Za prod (docker run -e API_BASE_URL=https://domen ...):
#   docker/config.template.js  →  envsubst na startup-u kontejnera generiše config.js
